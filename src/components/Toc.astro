---
import type { MarkdownHeading } from 'astro';
import { t } from '@/i18n/utils';

interface Props {
  headings: MarkdownHeading[];
}

const { headings = [] } = Astro.props;

// 支持 h1 ~ h6 所有层级
const filtersHeadings = headings
  ? headings.filter((item) => item.depth >= 1 && item.depth <= 6)
  : [];

const filtersHeadingsLength = filtersHeadings.length;
---

<div
  id="toc"
  class="sticky px-2 py-2 my-4 rounded-lg shadow-lg bg-skin-card top-4"
>
  <div class="aside-widget">
    <i class="ri-list-check menu-icon"></i>
    {t('blog.tableOfContent')}
  </div>
  <ul class="flex flex-col max-w-full mt-4 relative">
    {/* 贯穿整个目录的垂直引导线 */}
    <div class="absolute left-[7px] top-0 bottom-0 w-[1px] bg-skin-dodge"></div>

    {
      filtersHeadings.map((item, index) => {
        const isLast = index === filtersHeadingsLength - 1;
        const nextItem = !isLast ? filtersHeadings[index + 1] : null;
        // 判断当前标题下是否还有更深层的子标题
        const hasChildren = nextItem && nextItem.depth > item.depth;

        return (
          <li class:list={['flex items-start relative', `toc-depth-${item.depth}`]}>
            {/* 层级缩进容器 */}
            <div class="flex flex-shrink-0 relative" style={`width: ${(item.depth - 1) * 16 + 16}px;`}>
              {/* 各级垂直引导线 */}
              {Array.from({ length: item.depth }).map((_v, _i) => (
                <div
                  class="flex flex-col items-center flex-shrink-0"
                  style={`width: 16px;`}
                >
                  {/* 垂直线：从顶部贯穿到底部 */}
                  <div
                    class:list={[
                      'w-[1px] bg-skin-dodge',
                      // 最后一级使用L形拐角，其他级别使用完整垂直线
                      _i === item.depth - 1 ? 'h-[11px]' : 'h-full absolute top-0 bottom-0'
                    ]}
                  ></div>

                  {/* L形拐角的水平部分 */}
                  {_i === item.depth - 1 && (
                    <div class="flex items-center w-full h-[22px] relative">
                      {/* 水平短线 */}
                      <div class="w-[8px] h-[1px] bg-skin-dodge absolute left-0 top-[11px]"></div>
                    </div>
                  )}
                </div>
              ))}
            </div>

            <a
              title={item.slug}
              href={`#${item.slug}`}
              class:list={[
                'inline-block truncate py-[2px] hover:text-skin-active transition-colors',
                item.depth === 1 ? 'font-bold text-base' : '',
                item.depth === 2 ? 'text-sm' : '',
                item.depth === 3 ? 'text-xs' : '',
                item.depth === 4 ? 'text-xs' : '',
                item.depth === 5 ? 'text-xs' : '',
                item.depth === 6 ? 'text-xs' : '',
              ]}
            >
              {item.text}
            </a>
          </li>
        );
      })
    }
  </ul>

  <style>
    .toc_container {
      overflow-y: scroll;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .toc_container::-webkit-scrollbar {
      width: 0;
      height: 0;
    }

    .active-heading {
      color: #cc7a00;
      font-weight: 600;
    }

    /* 层级缩进 */
    .toc-depth-1 {
      padding-left: 0;
    }

    .toc-depth-2 {
      padding-left: 0;
    }

    .toc-depth-3 {
      padding-left: 0;
    }

    /* 引导线颜色 */
    .bg-skin-dodge {
      background-color: rgba(var(--color-text-dodge), 0.4);
    }
  </style>

  <script>
    function initTocScroll() {
      const toc = document.getElementById('toc');
      const anchors = document.querySelectorAll('h1, h2, h3, h4, h5, h6');
      const links = document.querySelectorAll('#toc > ul > li > a');
      if (!toc || anchors.length === 0 || links.length === 0) return;

      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -75% 0px',
        threshold: 0,
      };

      const callback = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            let index = Array.from(anchors).indexOf(entry.target);
            links.forEach((link) => {
              link.classList.remove('active-heading');
            });
            const activeLink = links[index] as HTMLElement;
            if (activeLink) {
              activeLink.classList.add('active-heading');
              // 自动滚动目录，使当前高亮项可见
              activeLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            }
          }
        });
      };

      const observer = new IntersectionObserver(callback, observerOptions);
      anchors.forEach((anchor) => {
        observer.observe(anchor);
      });
    }

    // 首次加载
    initTocScroll();
    // Astro View Transitions 页面切换后重新初始化
    document.addEventListener('astro:after-swap', initTocScroll);
  </script>
</div>
