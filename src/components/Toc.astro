---
import type { MarkdownHeading } from 'astro';
import { t } from '@/i18n/utils';

interface Props {
  headings: MarkdownHeading[];
}

const { headings = [] } = Astro.props;

// 支持 h1 ~ h6 所有层级
const filtersHeadings = headings
  ? headings.filter((item) => item.depth >= 1 && item.depth <= 6)
  : [];
---

<div
  id="toc"
  class="sticky px-2 py-2 my-4 rounded-lg shadow-lg bg-skin-card top-4"
>
  <div class="aside-widget">
    <i class="ri-list-check menu-icon"></i>
    {t('blog.tableOfContent')}
  </div>
  <div class="toc_container mt-4">
    <ul class="flex flex-col max-w-full">
    {
      filtersHeadings.map((item) => (
        <li class:list={[`toc-depth-${item.depth}`]}>
          <a
            title={item.slug}
            href={`#${item.slug}`}
            class:list={[
              'inline-block truncate py-[2px] hover:text-skin-active transition-colors',
              item.depth === 1 ? 'font-bold text-base' : '',
              item.depth === 2 ? 'text-sm' : '',
              item.depth === 3 ? 'text-xs' : '',
              item.depth === 4 ? 'text-xs' : '',
              item.depth === 5 ? 'text-xs' : '',
              item.depth === 6 ? 'text-xs' : '',
            ]}
          >
            {item.text}
          </a>
        </li>
      ))
    }
  </ul>
  </div>

  <style>
    .toc_container {
      max-height: 75vh;
      overflow-y: auto;
      scrollbar-width: thin;
      -ms-overflow-style: none;
    }

    .toc_container::-webkit-scrollbar {
      width: 4px;
    }

    .toc_container::-webkit-scrollbar-track {
      background: transparent;
    }

    .toc_container::-webkit-scrollbar-thumb {
      background: rgba(var(--color-text-dodge), 0.3);
      border-radius: 2px;
    }

    .toc_container::-webkit-scrollbar-thumb:hover {
      background: rgba(var(--color-text-dodge), 0.5);
    }

    .active-heading {
      color: #cc7a00;
      font-weight: 600;
    }

    /* 层级缩进 */
    .toc-depth-1 {
      padding-left: 0;
    }

    .toc-depth-2 {
      padding-left: 0;
    }

    .toc-depth-3 {
      padding-left: 0;
    }

    /* 引导线颜色 */
    .bg-skin-dodge {
      background-color: rgba(var(--color-text-dodge), 0.4);
    }
  </style>

  <script>
    function initTocScroll() {
      const toc = document.getElementById('toc');
      const container = toc?.querySelector('.toc_container') as HTMLElement;
      const anchors = document.querySelectorAll('.markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4, .markdown-body h5, .markdown-body h6');
      const links = container?.querySelectorAll('ul > li > a');
      if (!toc || !container || anchors.length === 0 || !links || links.length === 0) return;

      let ticking = false;

      function updateActiveHeading() {
        // 使用 getBoundingClientRect 获取标题相对视口的位置
        let currentIndex = 0;
        const offset = 120; // 距视口顶部的偏移量

        for (let i = anchors.length - 1; i >= 0; i--) {
          const rect = (anchors[i] as HTMLElement).getBoundingClientRect();
          if (rect.top <= offset) {
            currentIndex = i;
            break;
          }
        }

        // 高亮当前标题对应的目录项
        links.forEach((link) => link.classList.remove('active-heading'));
        const activeLink = links[currentIndex] as HTMLElement;
        if (!activeLink) return;

        activeLink.classList.add('active-heading');

        // 计算高亮项在目录容器中的相对位置
        const linkRect = activeLink.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();

        // 高亮项超出目录可视区域时，自动滚动
        if (linkRect.top < containerRect.top || linkRect.bottom > containerRect.bottom) {
          // 计算高亮项在容器内容中的绝对位置
          const scrollTarget = container.scrollTop + (linkRect.top - containerRect.top) - container.clientHeight / 3;
          container.scrollTo({
            top: Math.max(0, scrollTarget),
            behavior: 'smooth',
          });
        }
      }

      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          updateActiveHeading();
        });
      }

      // 初始定位
      updateActiveHeading();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    // 首次加载
    document.addEventListener('DOMContentLoaded', initTocScroll);
    // Astro View Transitions 页面切换后重新初始化
    document.addEventListener('astro:after-swap', initTocScroll);
  </script>
</div>
